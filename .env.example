# ---------------------------------------------------------------------------
# Optional: open-weights language model for the AI designer.
#
# Copy this file to `.env.local` and adjust. Everything here is optional —
# with no model configured the planner runs entirely on its built-in rules and
# geometry solver, offline, with no change to how the app behaves.
#
# The model is used for two things only:
#   1. reading a free-form description into a room schedule
#   2. proposing the adjacency graph (which rooms should adjoin which)
# All geometry — subdivision, circulation, doors, windows — stays deterministic.
# ---------------------------------------------------------------------------

# Master switch. Off by default: a local 7B takes 60-90 seconds per call, so
# the model path is opt-in rather than something that silently turns a
# two-second design into a three-minute one.
VITE_LLM_ENABLED=true

# Any OpenAI-compatible endpoint. Examples:
#   Ollama            http://localhost:11434/v1
#   llama.cpp server  http://localhost:8080/v1
#   LM Studio         http://localhost:1234/v1
#   vLLM              http://localhost:8000/v1
VITE_LLM_BASE_URL=http://localhost:11434/v1

# Preferred model. If this exact tag is not served, the client binds to the
# closest instruction-tuned model the endpoint reports, so a near miss still
# works. Good open-weights choices for this task:
#   qwen2.5:7b-instruct     balanced, strong at JSON output
#   llama3.1:8b-instruct    good general reasoning
#   mistral:7b-instruct     fastest of the three
#   qwen2.5:3b-instruct     best choice for interactive use on CPU
#
# Note on speed: the designer makes two calls (brief, then adjacency graph).
# On CPU a 7B costs roughly 60-90s each; a 3B is 3-4x faster and does these
# structured-output tasks nearly as well.
VITE_LLM_MODEL=qwen2.5:7b-instruct

# Only needed for hosted gateways (OpenRouter, Groq, Together). Leave blank
# for a local runtime. Never commit a real key — .env.local is gitignored.
VITE_LLM_API_KEY=

# Per-call ceiling in milliseconds. A local 7B on CPU needs 60-90s, and the
# first call also loads the weights. Lower it if you would rather fall back
# to the rule-based path quickly.
VITE_LLM_TIMEOUT_MS=90000
